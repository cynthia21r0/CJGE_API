generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(200)
  lastname   String   @db.VarChar(300)
  username   String   @db.VarChar(100)@unique
  password   String   @db.Text
  //refreshToken String?
  hash String?        @db.Text
  created_at DateTime @default(now())
  task       Task[]
  logs       Logs[]
}

model Task {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(150)
  description String   @db.VarChar(200)
  priority    Boolean
  user_id     Int
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

model Logs {
  id          Int @default(autoincrement()) @id
  statusCode  Int
  timestamp   DateTime
  path        String @db.Text()
  error       String @db.Text()
  errorCode   String @db.Text()
  session_id  Int
  user        User     @relation(fields: [session_id], references: [id])
}

//! Al hacer un cambio ejecutar: npx prisma generate
//! Se elimina la base de datos y despuejes ejecutar: npx prisma migrate dev